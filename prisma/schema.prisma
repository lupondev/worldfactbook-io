generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id                   String    @id @default(cuid())
  slug                 String    @unique
  ciaCode              String    @unique
  name                 String
  officialName         String?
  region               String
  subregion            String?
  flag                 String
  iso2                 String?
  iso3                 String?
  capital              String?
  area                 Float?
  population           BigInt?
  gdp                  Float?
  gdpPerCapita         Float?
  gdpGrowth            Float?
  inflation            Float?
  unemployment         Float?
  hdiRank              Int?
  hdiScore             Float?
  democracyScore       Int?
  corruptionIndex      Int?
  publicDebt           Float?
  imfCurrentAccountPct Float?
  imfGovBalancePct     Float?
  lifeExpectancy       Float?
  literacyRate         Float?
  introduction         String?   @db.Text
  geography            Json?
  peopleAndSociety     Json?
  government           Json?
  economy              Json?
  energy               Json?
  communications       Json?
  transportation       Json?
  military             Json?
  aiSummary            String?   @db.Text
  aiUpdatedAt          DateTime?
  dataUpdatedAt        DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model DataSource {
  id       String   @id @default(cuid())
  name     String
  lastSync DateTime
  status   String
}

model AutopilotLog {
  id        String   @id @default(cuid())
  runType   String
  status    String
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model BrainReport {
  id        String   @id @default(cuid())
  status    String
  summary   String?
  report    Json?
  createdAt DateTime @default(now())
}

model BlacklistedSource {
  id        String   @id @default(cuid())
  source    String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model ArticlePerformance {
  id         String   @id @default(cuid())
  articleId  String?
  slug       String?
  views      Int      @default(0)
  ctr        Float?
  bounceRate Float?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Entity {
  id                String           @id @default(cuid())
  type              String
  slug              String           @unique
  nameBs            String
  nameEn            String?
  role              String?
  shortBio          String?          @db.Text
  bioRich           String?          @db.Text
  imageUrl          String?
  avatar            String?
  activeFrom        DateTime?
  schemaKind        String           @default("Person")
  metadata          Json?
  isVerified        Boolean          @default(false)
  outgoingRelations Relation[]       @relation("FromEntity")
  incomingRelations Relation[]       @relation("ToEntity")
  entityDecisions   EntityDecision[]
  entityArticles    EntityArticle[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([type, isVerified])
  @@index([slug])
}

model Relation {
  id           String    @id @default(cuid())
  fromEntityId String
  toEntityId   String
  type         String
  since        DateTime?
  evidenceUrl  String?
  notes        String?
  fromEntity   Entity    @relation("FromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity     Entity    @relation("ToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@unique([fromEntityId, toEntityId, type])
}

model EntityDecision {
  id         String   @id @default(cuid())
  entityId   String
  decisionId String
  role       String
  context    String?  @db.Text
  createdAt  DateTime @default(now())
  entity     Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, decisionId])
  @@index([decisionId])
}

model EntityArticle {
  id          String    @id @default(cuid())
  entityId    String
  articleId   String
  title       String?
  url         String?
  slug        String?
  publishedAt DateTime?
  role        String
  createdAt   DateTime  @default(now())
  entity      Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, articleId])
  @@index([articleId])
  @@index([entityId])
}

model Decision {
  id              String    @id @default(cuid())
  articleId       String?
  slug            String?
  title           String?
  source          String    @default("OHR")
  sourceCaseId    String?
  defendant       String?
  decisionDate    DateTime?
  decisionType    String?
  pdfUrl          String?
  pdfHash         String?
  pdfBlobUrl      String?
  pageCount       Int?
  extractDeferred Boolean   @default(false)
  trustStatus     String    @default("ai_generated")
  impactScore     Float     @default(0)
  aiConfidence    Float?
  editorValidated Boolean   @default(false)
  version         Int       @default(1)
  needsDiffReview Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditLogs DecisionAuditLog[]
  signals   ArticleSignals?

  @@index([trustStatus])
  @@index([impactScore(sort: Desc)])
  @@index([version])
  @@index([needsDiffReview])
  @@index([source])
  @@index([sourceCaseId])
  @@index([decisionDate])
}

model ArticleSignals {
  id           String   @id @default(cuid())
  decisionId   String   @unique
  decision     Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  clusterScore Float?
  embeddingKey String?
  payload      Json?
  createdAt    DateTime @default(now())
}

model DecisionAuditLog {
  id         String   @id @default(cuid())
  decisionId String
  decision   Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  action     String
  actor      String
  actorLabel String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([decisionId])
  @@index([action])
  @@index([actor])
  @@index([createdAt(sort: Desc)])
}

model IngestLog {
  id           String   @id @default(cuid())
  sourceUrl    String
  sourceDomain String
  action       String
  reason       String?
  createdAt    DateTime @default(now())

  @@index([sourceDomain, action, createdAt])
  @@map("ingest_logs")
}
